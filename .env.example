# Copy this file to .env and fill in real values. .env is gitignored and
# will never be committed; this .example file is just the documented template.

# One-time seed only: only read the very first time state/state_telegram.json
# doesn't exist yet (and only if state/state_default.json, written by
# `python -m scripts.setup_region`, doesn't exist either). After that,
# state/state_telegram.json is the source of truth -- change region via the
# /setregion Telegram command instead.
REGION=

# Prices <= THRESHOLD are "ok", strictly above are "spike", below 0 is "negative".
# One-time seed only: only read the very first time state/state_telegram.json
# doesn't exist yet. After that, state/state_telegram.json is the source of
# truth and this is ignored -- change the threshold via the /setthreshold
# Telegram command instead.
THRESHOLD=30.0

TELEGRAM_CHAT_ID=
TELEGRAM_ALL_SLOTS_BOT_TOKEN=
TELEGRAM_ALERTS_BOT_TOKEN=
